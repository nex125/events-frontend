# --- Stage 1: Base deps ---
FROM oven/bun:1-alpine AS base
WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# --- Stage 2: Development ---
FROM base AS dev
WORKDIR /app
COPY . .
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
EXPOSE 3000
CMD ["bun", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]

# --- Stage 3: Builder ---
FROM base AS builder
WORKDIR /app
COPY . .
ARG INFRA_NEXT_PUBLIC_EVENT_TIME_ZONE
ARG INFRA_NEXT_PUBLIC_API_BASE_URL
ARG INFRA_API_BASE_URL
ARG INFRA_NEXT_PUBLIC_TICKETING_API_BASE_URL
ARG INFRA_TICKETING_API_BASE_URL
ARG INFRA_NEXT_PUBLIC_MERCURE_PUBLIC_URL
ARG INFRA_MERCURE_PUBLIC_URL
ARG INFRA_NEXT_PUBLIC_TICKETOK_WIDGET_SCRIPT_URL
ARG INFRA_NEXT_PUBLIC_TICKETOK_WIDGET_CSS_URL
ENV NEXT_PUBLIC_EVENT_TIME_ZONE=${INFRA_NEXT_PUBLIC_EVENT_TIME_ZONE}
ENV NEXT_PUBLIC_API_BASE_URL=${INFRA_NEXT_PUBLIC_API_BASE_URL}
ENV API_BASE_URL=${INFRA_API_BASE_URL}
ENV NEXT_PUBLIC_TICKETING_API_BASE_URL=${INFRA_NEXT_PUBLIC_TICKETING_API_BASE_URL}
ENV TICKETING_API_BASE_URL=${INFRA_TICKETING_API_BASE_URL}
ENV NEXT_PUBLIC_MERCURE_PUBLIC_URL=${INFRA_NEXT_PUBLIC_MERCURE_PUBLIC_URL}
ENV MERCURE_PUBLIC_URL=${INFRA_MERCURE_PUBLIC_URL}
ENV NEXT_PUBLIC_TICKETOK_WIDGET_SCRIPT_URL=${INFRA_NEXT_PUBLIC_TICKETOK_WIDGET_SCRIPT_URL}
ENV NEXT_PUBLIC_TICKETOK_WIDGET_CSS_URL=${INFRA_NEXT_PUBLIC_TICKETOK_WIDGET_CSS_URL}
ENV NEXT_TELEMETRY_DISABLED=1
RUN bun run build

# --- Stage 4: Production ---
FROM node:22-alpine AS prod
WORKDIR /app
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public
EXPOSE 3000
CMD ["node", "server.js"]
